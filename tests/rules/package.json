{
  "name": "@planner/rules-tests",
  "private": true,
  "version": "0.1.0",
  "description": "Unit tests for firestore.rules using the Firebase emulator.",
  "scripts": {
    "test": "firebase emulators:exec --only firestore --project=demo-planner \"vitest run\"",
    "test:watch": "firebase emulators:exec --only firestore --project=demo-planner \"vitest\""
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.1.0",
    "firebase-tools": "^13.29.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
