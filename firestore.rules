rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPERS
    // ============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // Safe role read: never throws if claim is missing.
    function userRole() {
      return isAuthenticated()
        ? (request.auth.token.role is string ? request.auth.token.role : '')
        : '';
    }

    function hasRole(role) {
      return userRole() == role;
    }

    function isAdmin() {
      return hasRole('ADMIN');
    }

    function isCoordinator() {
      return hasRole('COORDINATOR') || isAdmin();
    }

    function isTeacher() {
      return hasRole('TEACHER') || isCoordinator();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ============================================================
    // users
    // ============================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      allow create, delete: if isAdmin();

      // Non-admin users cannot change their role. Compare final vs previous
      // value directly so that sending the same role unchanged is allowed.
      allow update: if isAdmin()
        || (isOwner(userId)
            && request.resource.data.role == resource.data.role
            && request.resource.data.uid  == resource.data.uid);
    }

    // ============================================================
    // courses
    // ============================================================

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isCoordinator();
    }

    // ============================================================
    // careers
    // ============================================================

    match /careers/{careerId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ============================================================
    // teachers
    // ============================================================

    match /teachers/{teacherId} {
      allow get: if isOwner(teacherId) || isCoordinator();
      allow list: if isCoordinator();
      allow create, delete: if isCoordinator();
      allow update: if isOwner(teacherId) || isCoordinator();
    }

    // ============================================================
    // classrooms
    // ============================================================

    match /classrooms/{classroomId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isCoordinator();
    }

    // ============================================================
    // academic_periods
    // ============================================================

    match /academic_periods/{periodId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ============================================================
    // enrollments
    // ============================================================

    match /enrollments/{enrollmentId} {
      allow get: if isCoordinator()
        || (isAuthenticated() && resource.data.studentId == request.auth.uid);
      allow list: if isCoordinator();

      // A student may create their own enrollment as PENDING with sane totals.
      // Heavy validation (credits, prerequisites) happens server-side in a
      // Cloud Function that promotes the enrollment to VALIDATED.
      allow create: if isAuthenticated()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.status == 'PENDING'
        && request.resource.data.totalCredits is number
        && request.resource.data.totalCredits >= 0
        && request.resource.data.totalCredits <= 30
        && request.resource.data.selectedCourses is list
        && request.resource.data.selectedCourses.size() > 0
        && request.resource.data.selectedCourses.size() <= 10;

      allow update, delete: if isCoordinator();
    }

    // ============================================================
    // schedules (read-only for clients; written by Functions via Admin SDK)
    // ============================================================

    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ============================================================
    // default deny
    // ============================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
